APP_ENV=development
FRONTEND_ORIGINS=http://localhost:3000

# MongoDB Atlas: Database > Connect > Drivers > Python
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=launchkit

# Auth0 API settings. The domain must not include https://.
AUTH0_DOMAIN=<tenant>.us.auth0.com
AUTH0_AUDIENCE=https://launchkit-api

# Google AI Studio
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
