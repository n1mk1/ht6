PRAXIS_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
PRAXIS_MONGODB_DB=praxis
PRAXIS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PRAXIS_DEVICE_KEY=
PRAXIS_ENVIRONMENT=development

# Real FreeSOLO service. Both model and API key are required for requests.
PRAXIS_FREESOLO_MODE=http
# Use openai_base_url from `flash deployments --json`, plus `/chat/completions`.
PRAXIS_FREESOLO_ENDPOINT=https://clado-ai--freesolo-lora-serving.modal.run/v1/chat/completions
PRAXIS_FREESOLO_MODEL=
PRAXIS_FREESOLO_API_KEY=
PRAXIS_FREESOLO_TIMEOUT_SECONDS=20

# Development only. Rejected when PRAXIS_ENVIRONMENT=production.
# PRAXIS_FREESOLO_MODE=mock
